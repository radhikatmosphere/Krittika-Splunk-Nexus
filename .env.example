# ============================================================================
# Krittika-Splunk Nexus — Environment Configuration
# Domain: radhikachain.xyz
# Copy to .env and fill in all values before deployment
# ============================================================================

# ----------------------------------------------------------------------------
# Cloudflare Tunnel (Zero-Trust Ingress)
# ----------------------------------------------------------------------------
# Create tunnel: cloudflared tunnel create krittika-nexus
# Get token from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ----------------------------------------------------------------------------
# Splunk Enterprise (Self-Hosted on Linode)
# ----------------------------------------------------------------------------
# Admin password for Splunk Web UI
SPLUNK_PASSWORD=your-secure-splunk-password-here

# HEC Token for agent audit trail ingestion (create in Splunk: Settings > Data Inputs > HTTP Event Collector)
SPLUNK_HEC_TOKEN=your-hec-token-here

# MCP Server Token (install MCP Server app from Splunkbase, create encrypted token)
MCP_TOKEN=your-encrypted-mcp-token-here

# ----------------------------------------------------------------------------
# Universal Forwarder (deployed on each RadhikaChain validator node)
# ----------------------------------------------------------------------------
SPLUNK_FORWARDER_PASSWORD=your-forwarder-password-here

# ----------------------------------------------------------------------------
# Agent Configuration
# ----------------------------------------------------------------------------
# Audit index name (must match index created in Splunk Enterprise)
AUDIT_INDEX=krittika_audit

# Polling interval in seconds
POLL_INTERVAL=30

# Latency threshold (ms) — triggers remediation
LATENCY_THRESHOLD_MS=500

# Threat count threshold — triggers isolation
THREAT_COUNT_THRESHOLD=3

# Demo mode (false for production, true for local testing with test_datasets/)
DEMO_MODE=false

# ----------------------------------------------------------------------------
# Fleet API Server (agent_core/api_server.py)
# ----------------------------------------------------------------------------
# Exposes live fleet status via HTTP for the web frontend
# Route: api.radhikachain.xyz (via Cloudflare Tunnel)
API_HOST=0.0.0.0
API_PORT=8080

# ----------------------------------------------------------------------------
# Connectivity Test Script (scripts/test_nexus_endpoints.py)
# These are auto-populated from the above when using docker-compose.cloud.yml
# ----------------------------------------------------------------------------
# SPLUNK_WEB_URL=https://splunk.radhikachain.xyz
# SPLUNK_HEC_URL=https://hec.radhikachain.xyz/services/collector
# MCP_ENDPOINT=https://mcp.radhikachain.xyz/services/mcp